---
import CreateAsset from "../../../components/react/portfolios/createAsset"
import RootLayout from "../../../layouts/rootLayout.astro"
---
<RootLayout title="portfolios id" description="portfolios id">
 <div class="flex flex-col p-2">
<div class="overflow-x-auto">
  <div class="min-w-full inline-block align-middle">
      <div class="relative grid grid-cols-4 gap-4 items-center mb-5">
        <div class="col-span-1">
            <CreateAsset client:only="react"/>
        </div>
        <div class="col-span-3">
          <div class="absolute inset-y-0 right flex items-center pr-3 pointer-events-none">
              <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="..." stroke="currentColor" style={{ color: 'var(--gh-fg-muted)' }} stroke-width="1.6" stroke-linecap="round" />
                  <path d="..." stroke="currentColor" stroke-opacity="0.2" stroke-width="1.6" stroke-linecap="round" />
                  <path d="..." stroke="currentColor" stroke-opacity="0.2" stroke-width="1.6" stroke-linecap="round" />
              </svg>
          </div>
          <input type="text" class="search-input" placeholder="Search for company">
        </div>
      </div>
      <div class="overflow-hidden rounded-lg p-1" style={{ border: '1px solid var(--gh-border)' }}>
          <table class="min-w-full">
              <thead>
                  <tr style={{ backgroundColor: 'var(--gh-bg-subtle)' }}>
                      <th scope="col" class="p-5 text-right text-sm leading-6 font-semibold capitalize rounded-tr-lg" style={{ color: 'var(--gh-fg)' }}>
                        نام دارایی
                      </th>
                      <th scope="col" class="p-5 text-right text-sm leading-6 font-semibold capitalize" style={{ color: 'var(--gh-fg)' }}>
                        مقدار
                      </th>
                      <th scope="col" class="p-5 text-right text-sm leading-6 font-semibold capitalize" style={{ color: 'var(--gh-fg)' }}>
                        قیمت فعلی
                      </th>
                      <th scope="col" class="p-5 text-right text-sm leading-6 font-semibold capitalize" style={{ color: 'var(--gh-fg)' }}>
                        مدت زمان نگهداری
                      </th>
                      <th scope="col" class="p-5 text-right text-sm leading-6 font-semibold capitalize rounded-tl-lg" style={{ color: 'var(--gh-fg)' }}>
                        میانگین خرید
                      </th>
                      <th scope="col" class="p-5 text-right text-sm leading-6 font-semibold capitalize rounded-tl-lg" style={{ color: 'var(--gh-fg)' }}>
                        سود / ضرر
                      </th>
                      <th scope="col" class="p-5 text-right text-sm leading-6 font-semibold capitalize rounded-tl-lg" style={{ color: 'var(--gh-fg)' }}>
                        عملیات
                      </th>
                  </tr>
              </thead>
              <tbody class="divide-y table-container">
                  <tr class="transition-all duration-500 hover-row" style={{ backgroundColor: 'var(--gh-bg)' }}>
                      <td class="whitespace-nowrap p-5 text-sm font-medium capitalize" style={{ color: 'var(--gh-fg)' }}>
                          <div class="flex items-center">
                              <span class="font-medium me-3" style={{ color: 'var(--gh-fg)' }}>Bitcoin</span>
                          </div>
                      </td>
                      <td class="p-5 text-sm font-medium capitalize" style={{ color: 'var(--gh-fg-secondary)' }}>0.056</td>
                      <td class="p-5 text-sm font-medium capitalize" style={{ color: 'var(--gh-fg-secondary)' }}>$37,171</td>
                      <td class="p-5 text-sm font-medium capitalize" style={{ color: 'var(--gh-fg-secondary)' }}>10%</td>
                      <td class="p-5 text-sm font-medium capitalize" style={{ color: 'var(--gh-fg-secondary)' }}>$29,434</td>
                      <td class="p-5 text-sm font-medium capitalize" style={{ color: 'var(--gh-success-fg)' }}>+$4,327</td>
                      <td class="flex gap-x-2 p-5">
                          <a href="#/" class="rounded-md p-2 transition-colors duration-150" style={{ color: 'var(--gh-accent-emphasis)' }}>
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                              </svg>
                          </a>
                          <a href="#/" class="rounded-md p-2 transition-colors duration-150" style={{ color: 'var(--gh-danger-emphasis)' }}>
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                              </svg>
                          </a>
                      </td>
                  </tr>
              </tbody>
          </table>
      </div>
  </div>
</div>
</div>
</RootLayout>
