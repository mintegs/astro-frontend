---
import RootLayout from '../../layouts/rootLayout.astro'
---

<RootLayout
  title='article page'
  description='articles page description'
>
  <!-- Hero Content Start -->
  <div class='mx-auto max-w-[1170px] px-4 sm:px-8 xl:px-0 relative z-1'>
    <div class='flex flex-wrap gap-x-7.5 gap-y-9'>
      <!-- Hero item (main) -->
      <div
        class='max-w-[1170px] w-full flex flex-col lg:flex-row lg:items-center gap-7.5 lg:gap-11 shadow-1 rounded-xl p-4 lg:p-2.5'
        style={{ backgroundColor: 'var(--gh-surface)' }}
      >
        <div class='lg:max-w-[536px] w-full'>
          <a href='/article/1'>
            <img class='w-full rounded-md' src='https://picsum.photos/521/312' alt='hero' />
          </a>
        </div>
        <div class='lg:max-w-[540px] w-full'>
          <a href='category.html'
            class='inline-flex font-medium text-sm py-1 px-3 rounded-full mb-4'
            style={{ color: 'var(--gh-accent-fg)', backgroundColor: 'var(--gh-accent-subtle)' }}
          >لایف استایل</a>
          <h1 class='font-bold text-custom-4 xl:text-heading-4 mb-4' style={{ color: 'var(--gh-fg)' }}>
            <a href='blog-single.html'>
              از اینجا شروع کنید تا یک خلاصه کوتاه شامل تمام موارد ضروری به‌دست آورید.
            </a>
          </h1>
          <p class='max-w-[524px]' style={{ color: 'var(--gh-fg-secondary)' }}>...</p>
          <div class='flex items-center gap-2.5 mt-5'>
            <a href='/article/1' class='flex items-center gap-3'>
              <div class='flex w-6 h-6 rounded-full overflow-hidden'>
                <img src='https://clarity-tailwind.preview.uideck.com/images/user-01.png' alt='user' />
              </div>
              <p class='text-sm' style={{ color: 'var(--gh-fg)' }}>محمدرضا آریک</p>
            </a>
            <span class='flex w-[3px] h-[3px] rounded-full' style={{ backgroundColor: 'var(--gh-fg-muted)' }}></span>
            <p class='text-sm' style={{ color: 'var(--gh-fg-muted)' }}>۱۰ شهریور - ۱۴۰۴</p>
          </div>
        </div>
      </div>

      <div class='grid grid-cols-1 lg:grid-cols-2 gap-4'>
        <!-- Hero item (tech) -->
        <div class='lg:max-w-[570px] w-full flex flex-col sm:flex-row sm:items-center gap-6 shadow-1 rounded-xl p-2.5' style={{ backgroundColor: 'var(--gh-surface)' }}>
          <div class='lg:max-w-[238px] w-full'>
            <a href='blog-single.html'>
              <img class='w-full rounded-md' src='https://picsum.photos/238/180' alt='hero' />
            </a>
          </div>
          <div class='lg:max-w-[272px] w-full'>
            <a href='category.html'
              class='inline-flex font-medium text-sm py-1 px-3 rounded-full mb-4'
              style={{ color: 'var(--gh-accent-fg)', backgroundColor: 'var(--gh-accent-subtle)' }}
            >تکنولوژی</a>
            <h2 class='font-semibold text-custom-lg mb-3' style={{ color: 'var(--gh-fg)' }}>...</h2>
            <div class='flex items-center gap-2.5'>
              <p class='text-sm' style={{ color: 'var(--gh-fg)' }}><a href='author.html'>محمدرضا آریک</a></p>
              <span class='flex w-[3px] h-[3px] rounded-full' style={{ backgroundColor: 'var(--gh-fg-muted)' }}></span>
              <p class='text-sm' style={{ color: 'var(--gh-fg-muted)' }}>۱۰ شهریور - ۱۴۰۴</p>
            </div>
          </div>
        </div>

        <!-- Hero item (travel) -->
        <div class='lg:max-w-[570px] w-full flex flex-col sm:flex-row sm:items-center gap-6 shadow-1 rounded-xl p-2.5' style={{ backgroundColor: 'var(--gh-surface)' }}>
          <div class='lg:max-w-[238px] w-full'>
            <a href='blog-single.html'>
              <img class='w-full rounded-md' src='https://picsum.photos/238/180' alt='hero' />
            </a>
          </div>
          <div class='lg:max-w-[272px] w-full'>
            <a href='category.html'
              class='inline-flex font-medium text-sm py-1 px-3 rounded-full mb-4'
              style={{ color: 'var(--gh-success-fg)', backgroundColor: 'var(--gh-success-subtle)' }}
            >Travel</a>
            <h2 class='font-semibold text-custom-lg mb-3' style={{ color: 'var(--gh-fg)' }}>...</h2>
            <div class='flex items-center gap-2.5'>
              <p class='text-sm' style={{ color: 'var(--gh-fg)' }}><a href='author.html'>By Adrio Devid</a></p>
              <span class='flex w-[3px] h-[3px] rounded-full' style={{ backgroundColor: 'var(--gh-fg-muted)' }}></span>
              <p class='text-sm' style={{ color: 'var(--gh-fg-muted)' }}>Sep 10, 2025</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Hero Content End -->
</RootLayout>
