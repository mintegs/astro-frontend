---
const { layout } = Astro.props
---
<div class='bento-card' data-layout={layout}>
  <div class='card bento-card-inner'>
    <slot />
  </div>
</div>

<style>
  .bento-card-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .bento-card[data-layout='large'] .bento-card-inner { min-height: 420px; }
  .bento-card[data-layout='medium'] .bento-card-inner { min-height: 260px; }
  .bento-card[data-layout='small'] .bento-card-inner { min-height: 160px; }
  .bento-card[data-layout='half'] .bento-card-inner { min-height: 300px; }
  .bento-card[data-layout='full'] .bento-card-inner { min-height: 420px; }
</style>
