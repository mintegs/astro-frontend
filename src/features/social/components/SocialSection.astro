---
import BentoCard from '../../../components/astro/profile/BentoCard.astro'
import SocialCard from './SocialCard.astro'
import socials from '../data/socials'
---

<section class='social-section' aria-label='Social Links'>
  <BentoCard layout='half'>
    <h3 class='section-title'>شبکه‌های اجتماعی</h3>
    <div class='socials-list'>
      {socials.map((s) => (
        <SocialCard social={s} />
      ))}
    </div>
  </BentoCard>
</section>

<style>
  .social-section {
    margin-top: 24px;
  }

  .section-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gh-fg);
    margin-bottom: 12px;
  }

  .socials-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
</style>
