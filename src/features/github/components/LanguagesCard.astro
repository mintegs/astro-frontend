---
import type { Language } from '../types'

interface Props {
  languages: Language[]
}

const { languages } = Astro.props
const totalPercentage = languages.reduce((sum, l) => sum + l.percentage, 0)
---

<div class='languages-bar'>
  {languages.slice(0, 5).map((lang) => (
    <div
      class='languages-bar-segment'
      style={`width: ${(lang.percentage / totalPercentage) * 100}%; background-color: ${lang.color}`}
      title={`${lang.name}: ${lang.percentage}%`}
    />
  ))}
</div>

<div class='languages-list'>
  {languages.map((lang) => (
    <div class='languages-item'>
      <div class='languages-item-left'>
        <span class='languages-dot' style={`background-color: ${lang.color}`} />
        <span class='languages-name'>{lang.name}</span>
      </div>
      <div class='languages-item-right'>
        <span class='languages-percent'>{lang.percentage}%</span>
        <span class='languages-repos'>{lang.repoCount} مخزن</span>
      </div>
    </div>
  ))}
</div>

<style>
  .languages-bar {
    display: flex;
    height: 8px;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 16px;
    background-color: var(--gh-bg-subtle);
  }

  .languages-bar-segment {
    height: 100%;
    transition: opacity 0.15s ease;
  }

  .languages-bar-segment:first-child {
    border-radius: 4px 0 0 4px;
  }

  .languages-bar-segment:last-child {
    border-radius: 0 4px 4px 0;
  }

  .languages-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .languages-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 0;
  }

  .languages-item-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .languages-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .languages-name {
    font-size: 0.8125rem;
    color: var(--gh-fg);
  }

  .languages-item-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .languages-percent {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gh-fg);
    min-width: 36px;
    text-align: left;
  }

  .languages-repos {
    font-size: 0.6875rem;
    color: var(--gh-fg-muted);
  }
</style>
