---
import type {
  Achievement,
  ActivityEvent,
  ContributionData,
  Framework,
  Language,
  Organization,
  Repository,
} from '../types'

import BentoCard from '../../../components/astro/profile/BentoCard.astro'
import AchievementsCard from './AchievementsCard.astro'
import ActivityFeed from './ActivityFeed.astro'
import ContributionGraph from './ContributionGraph.astro'
import FrameworksCard from './FrameworksCard.astro'
import LanguagesCard from './LanguagesCard.astro'
import OrganizationsCard from './OrganizationsCard.astro'
import RepositoryCard from './RepositoryCard.astro'

interface Props {
  contributionData: ContributionData
  activity: ActivityEvent[]
  languages: Language[]
  frameworks: Framework[]
  organizations: Organization[]
  achievements: Achievement[]
  repositories: Repository[]
}

const {
  contributionData,
  activity,
  languages,
  frameworks,
  organizations,
  achievements,
  repositories,
} = Astro.props

const pinnedRepos = repositories.filter((r) => r.isPinned).slice(0, 6)
---

<section
  class='github-dashboard'
  aria-label='GitHub Dashboard'
>
  <h2 class='dashboard-title'>GitHub</h2>

  <div class='bento-grid'>
    <div class='bento-card' data-layout='full'>
      <div class='card github-unified-card'>
        <div class='gh-section'>
          <h3 class='gh-section-title'>زبان‌ها</h3>
          <LanguagesCard languages={languages} />
        </div>

        <div class='gh-divider' role='separator'></div>

        <div class='gh-section'>
          <ContributionGraph data={contributionData} />
        </div>

        {pinnedRepos.length > 0 && (
          <Fragment>
            <div class='gh-divider' role='separator'></div>
            <div class='gh-section'>
              <h3 class='gh-section-title'>مخازن منتخب</h3>
              <div class='repos-grid'>
                {pinnedRepos.map((repo) => <RepositoryCard repo={repo} />)}
              </div>
            </div>
          </Fragment>
        )}
      </div>
    </div>

    <BentoCard layout='large'>
      <h3 class='section-title'>فعالیت اخیر</h3>
      <ActivityFeed events={activity} />
    </BentoCard>

    <BentoCard layout='medium'>
      <h3 class='section-title'>فریمورک‌ها و ابزارها</h3>
      <FrameworksCard frameworks={frameworks} />
    </BentoCard>

    <BentoCard layout='medium'>
      <h3 class='section-title'>دستاوردها</h3>
      <AchievementsCard achievements={achievements} />
    </BentoCard>

    <BentoCard layout='half'>
      <h3 class='section-title'>سازمان‌ها</h3>
      <OrganizationsCard organizations={organizations} />
    </BentoCard>
  </div>
</section>

<style>
  .github-dashboard {
    margin-top: 24px;
  }

  .dashboard-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--gh-fg);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--gh-border-muted);
  }

  .github-unified-card {
    padding: 24px;
  }

  .gh-section-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gh-fg);
    margin-bottom: 16px;
  }

  .gh-divider {
    height: 1px;
    background-color: var(--gh-border-muted);
    margin: 24px 0;
    border: none;
  }

  .repos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 1024px) {
    .repos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .repos-grid {
      grid-template-columns: 1fr;
    }
  }

  .section-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gh-fg);
    margin-bottom: 12px;
  }
</style>
