---
import type { ContributionData, ContributionDay } from '../types'

interface Props {
  data: ContributionData
}

const { data } = Astro.props
const { availableYears, selectedYear, years } = data

function toPersianDigits(n: number): string {
  return n.toString().replace(/\d/g, (d) => '۰۱۲۳۴۵۶۷۸۹'[Number(d)])
}

interface GridWeek {
  days: (ContributionDay | null)[]
}

function buildYearGrid(yearData: ContributionData['years'][number]): {
  weeks: GridWeek[]
  totalWeeks: number
} {
  const dayMap = new Map(yearData.days.map((d) => [d.date, d]))
  const year = yearData.year

  const jan1 = new Date(year, 0, 1)
  const dec31 = new Date(year, 11, 31)

  const gridStart = new Date(jan1)
  gridStart.setDate(gridStart.getDate() - jan1.getDay())

  const gridEnd = new Date(dec31)
  gridEnd.setDate(gridEnd.getDate() + (6 - dec31.getDay()))

  const weeks: GridWeek[] = []
  let currentWeek: (ContributionDay | null)[] = []
  const cursor = new Date(gridStart)

  while (cursor <= gridEnd) {
    const dateStr = `${cursor.getFullYear()}-${String(cursor.getMonth() + 1).padStart(2, '0')}-${String(cursor.getDate()).padStart(2, '0')}`
    const dayData = dayMap.get(dateStr) ?? null
    currentWeek.push(dayData)

    if (currentWeek.length === 7) {
      weeks.push({ days: currentWeek })
      currentWeek = []
    }

    cursor.setDate(cursor.getDate() + 1)
  }

  if (currentWeek.length > 0) {
    while (currentWeek.length < 7) currentWeek.push(null)
    weeks.push({ days: currentWeek })
  }

  return { weeks, totalWeeks: weeks.length }
}

const grids = availableYears.map((y) => ({
  year: y,
  grid: buildYearGrid(years[y]),
  total: years[y].total,
}))

const defaultGrid = grids.find((g) => g.year === selectedYear) ?? grids[0]
---

<div
  class='contrib-graph'
  data-component='contribution-graph'
>
  <div class='contrib-header'>
    <h3
      class='contrib-title'
      id='contrib-title'
    >
      مشارکت در سال {toPersianDigits(defaultGrid.year)}
    </h3>
    <div class='contrib-year-selector'>
      <label
        for='contrib-year-select'
        class='sr-only'
        >سال</label
      >
      <select
        id='contrib-year-select'
        class='contrib-year-select'
      >
        {
          [...availableYears].reverse().map((y) => (
            <option
              value={y}
              selected={y === selectedYear}
            >
              {toPersianDigits(y)}
            </option>
          ))
        }
      </select>
    </div>
  </div>

  {
    grids.map(({ year, grid, total }) => (
      <div
        class='contrib-year-panel'
        data-year={year}
        data-total={total.toLocaleString()}
        style={year !== selectedYear ? 'display:none' : undefined}
      >
        <div class='contrib-grid-scroll'>
          <div
            class='contrib-grid-wrapper'
            dir='ltr'
          >
            <div
              class='contrib-grid'
              style={`grid-template-columns: repeat(${grid.totalWeeks}, 1fr)`}
            >
              {grid.weeks.map((week) =>
                week.days.map((day) => {
                  if (day === null) {
                    return <div class='contrib-day contrib-day-empty' />
                  }
                  return (
                    <div
                      class={`contrib-day contrib-day-filled contrib-level-${day.level}`}
                    />
                  )
                }),
              )}
            </div>
          </div>
        </div>
      </div>
    ))
  }

  <div class='contrib-footer'>
    <span
      class='contrib-total'
      id='contrib-total'
    >
      {defaultGrid.total.toLocaleString()} مشارکت
    </span>
    <div class='contrib-legend'>
      <span class='contrib-legend-label'>کمتر</span>
      <div class='contrib-day contrib-level-0 contrib-legend-cell'></div>
      <div class='contrib-day contrib-level-1 contrib-legend-cell'></div>
      <div class='contrib-day contrib-level-2 contrib-legend-cell'></div>
      <div class='contrib-day contrib-level-3 contrib-legend-cell'></div>
      <div class='contrib-day contrib-level-4 contrib-legend-cell'></div>
      <span class='contrib-legend-label'>بیشتر</span>
    </div>
  </div>
</div>

<script>
  function toPersianDigits(n: number): string {
    return n.toString().replace(/\d/g, (d) => '۰۱۲۳۴۵۶۷۸۹'[Number(d)])
  }

  function initContributionGraph() {
    const select = document.getElementById(
      'contrib-year-select',
    ) as HTMLSelectElement | null
    if (!select) return

    select.addEventListener('change', () => {
      const year = Number(select.value)
      const panels = document.querySelectorAll('.contrib-year-panel')
      const title = document.getElementById('contrib-title')
      const total = document.getElementById('contrib-total')

      panels.forEach((panel) => {
        const el = panel as HTMLElement
        if (Number(el.dataset.year) === year) {
          el.style.display = ''
        } else {
          el.style.display = 'none'
        }
      })

      if (title) {
        title.textContent = `مشارکت در سال ${toPersianDigits(year)}`
      }

      const activePanel = document.querySelector(
        `.contrib-year-panel[data-year="${year}"]`,
      )
      if (total) {
        const count = activePanel?.getAttribute('data-total') ?? '0'
        total.textContent = `${count} مشارکت`
      }
    })
  }

  document.addEventListener('DOMContentLoaded', initContributionGraph)
</script>

<style>
  .contrib-graph {
    display: flex;
    flex-direction: column;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .contrib-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .contrib-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gh-fg);
    margin: 0;
  }

  .contrib-year-select {
    padding: 4px 28px 4px 8px;
    font-size: 0.8125rem;
    font-family: inherit;
    color: var(--gh-fg);
    background-color: var(--gh-bg-subtle);
    border: 1px solid var(--gh-border);
    border-radius: 6px;
    cursor: pointer;
    outline: none;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
    appearance: auto;
  }
  .contrib-year-select:hover {
    border-color: var(--gh-fg-muted);
  }
  .contrib-year-select:focus {
    border-color: var(--gh-accent);
    box-shadow: 0 0 0 3px rgba(9, 105, 218, 0.15);
  }
  [data-theme='dark'] .contrib-year-select:focus {
    box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.15);
  }

  .contrib-grid-scroll {
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .contrib-grid-wrapper {
    display: grid;
  }

  .contrib-grid {
    display: grid;
    grid-template-rows: repeat(7, 1fr);
    gap: 3px;
  }

  .contrib-day {
    aspect-ratio: 1;
    min-width: 0;
    min-height: 0;
    border-radius: 2px;
    outline: 1px solid rgba(27, 31, 36, 0.06);
    position: relative;
  }

  .contrib-day-empty {
    background: transparent;
    outline: none;
  }

  .contrib-level-0 {
    background-color: var(--contrib-0);
  }
  .contrib-level-1 {
    background-color: var(--contrib-1);
  }
  .contrib-level-2 {
    background-color: var(--contrib-2);
  }
  .contrib-level-3 {
    background-color: var(--contrib-3);
  }
  .contrib-level-4 {
    background-color: var(--contrib-4);
  }

  .contrib-day-filled {
    cursor: default;
  }

  .contrib-day-filled:hover {
    outline: 1px solid var(--gh-fg-muted);
    outline-offset: -1px;
  }

  .contrib-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 12px;
  }

  .contrib-legend {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .contrib-legend-label {
    font-size: 10px;
    color: var(--gh-fg-muted);
    margin: 0 2px;
  }

  .contrib-legend-cell {
    width: 11px;
    height: 11px;
  }

  .contrib-total {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--gh-fg-muted);
  }
</style>
