---
const { repo } = Astro.props
---
<article class='card repo-card p-3'>
  <div class='repo-header'>
    <div class='repo-title-row'>
      <a href={repo.url} target='_blank' rel='noopener noreferrer' class='repo-name'>{repo.name}</a>
      {repo.isPinned && <span class='repo-pinned'> pin</span>}
    </div>
    <div class='repo-desc'>{repo.description}</div>
  </div>

  <div class='repo-meta'>
    <div class='repo-lang'>
      <span class='repo-lang-dot' style={`background-color: ${repo.languageColor}`} />
      <span>{repo.language}</span>
    </div>
    {repo.frameworks && repo.frameworks.length > 0 && (
      <div class='repo-tags'>
        {repo.frameworks.map((fw: string) => (
          <span class='repo-tag'>{fw}</span>
        ))}
      </div>
    )}
  </div>

  <div class='repo-stats'>
    <span class='repo-stat'>⭐ {repo.stars}</span>
    <span class='repo-stat'>🔱 {repo.forks}</span>
    <span class='repo-stat repo-updated'>{repo.updatedAt}</span>
  </div>
</article>

<style>
  .repo-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.15s ease;
  }

  .repo-card:hover {
    border-color: var(--gh-border);
  }

  .repo-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .repo-title-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .repo-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gh-accent);
    text-decoration: none;
  }

  .repo-name:hover {
    text-decoration: underline;
  }

  .repo-pinned {
    font-size: 0.625rem;
    color: var(--gh-fg-muted);
    font-weight: 400;
  }

  .repo-desc {
    font-size: 0.75rem;
    color: var(--gh-fg-secondary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .repo-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .repo-lang {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    color: var(--gh-fg-secondary);
  }

  .repo-lang-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .repo-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .repo-tag {
    font-size: 0.625rem;
    padding: 1px 6px;
    border-radius: 12px;
    background-color: var(--gh-accent-subtle);
    color: var(--gh-accent);
    font-weight: 500;
    white-space: nowrap;
  }

  .repo-stats {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 6px;
    border-top: 1px solid var(--gh-border-muted);
  }

  .repo-stat {
    font-size: 0.75rem;
    color: var(--gh-fg-muted);
  }

  .repo-updated {
    margin-left: auto;
  }
</style>
